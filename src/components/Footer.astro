---
import Sparkle from './Sparkle.astro';
import type { Locale } from '../utils/i18n';
import { t, localePath } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();

const navLinks = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.gallery', path: '/gallery' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.contact', path: '/contact' },
];
---

<footer class="border-t border-brand-gold/10 bg-brand-purple-dark mt-auto">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row justify-between gap-10">

      <div class="max-w-xs flex flex-col gap-4">
        <a
          href={localePath(locale, '/')}
          class="font-display text-2xl tracking-[0.2em] uppercase text-brand-cream hover:text-brand-gold transition-colors"
        >
          Immersia Events
        </a>
        <a
          href="https://discord.gg/D65m6sgSqk"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm tracking-wide text-brand-gold/80 hover:text-brand-gold transition-colors"
        >
          {t(locale, 'footer.discord')} →
        </a>
      </div>

      <nav aria-label={locale === 'fi' ? 'Alatunnisteen navigaatio' : 'Footer navigation'}>
        <ul class="flex flex-col gap-2" role="list">
          {navLinks.map(({ key, path }) => (
            <li>
              <a
                href={localePath(locale, path)}
                class="text-sm tracking-wide text-brand-cream/60 hover:text-brand-cream transition-colors"
              >
                {t(locale, key)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

  <div class="border-t border-brand-gold/10">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <Sparkle size={10} class="text-brand-gold/40" />
        <p class="text-xs text-brand-cream/40 tracking-wide">
          &copy; {year} {t(locale, 'footer.legal_name')}. {t(locale, 'footer.rights')}
        </p>
      </div>
      <p class="text-xs text-brand-cream/30 tracking-wide text-center sm:text-right">
        {t(locale, 'footer.legal_person')} &middot; {t(locale, 'footer.legal_id')}
      </p>
    </div>
  </div>
</footer>
