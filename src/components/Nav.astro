---
import { Image } from 'astro:assets';
import { Globe, Menu } from 'lucide-astro';
import logoImg from '../assets/logo.svg';
import type { Locale } from '../utils/i18n';
import { t, localePath } from '../utils/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const navLinks = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.event', path: '/events/river-court-autumn-ball' },
  { key: 'nav.gallery', path: '/gallery' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.contact', path: '/contact' },
];

function isActive(path: string): boolean {
  const full = localePath(locale, path);
  if (path === '/') return currentPath === full;
  return currentPath.startsWith(full);
}

const pathWithoutLocale = locale === 'en' ? currentPath.replace(/^\/en/, '') || '/' : currentPath;
const fiHref = pathWithoutLocale;
const enHref = `/en${pathWithoutLocale === '/' ? '' : pathWithoutLocale}`;
---

<header>
  <nav
    id="site-nav"
    aria-label={locale === 'fi' ? 'Päänavigaatio' : 'Main navigation'}
    class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300"
  >
    <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">

      <a
        href={localePath(locale, '/')}
        aria-label={t(locale, 'meta.site_name')}
        class="shrink-0"
      >
        <Image src={logoImg} alt="Immersia Events" height={80} width={80} class="h-16 md:h-20 w-auto" />
      </a>

      <!-- Desktop navigation -->
      <ul class="hidden md:flex items-center gap-8" role="list">
        {navLinks.map(({ key, path }) => (
          <li class="flex items-center">
            <a
              href={localePath(locale, path)}
              aria-current={isActive(path) ? 'page' : undefined}
              class:list={[
                'flex items-center leading-none text-xs tracking-[0.15em] uppercase font-body transition-colors',
                isActive(path)
                  ? 'text-brand-gold'
                  : 'text-brand-cream/80 hover:text-brand-cream',
              ]}
            >
              {t(locale, key)}
            </a>
          </li>
        ))}

        <!-- Language switcher as last nav item -->
        <li class="relative flex items-center ml-2">
          <button
            id="lang-toggle"
            type="button"
            aria-expanded="false"
            aria-haspopup="listbox"
            class="flex cursor-pointer items-center gap-1.5 leading-none text-xs tracking-[0.15em] uppercase text-brand-cream/80 hover:text-brand-cream transition-colors"
            aria-label={t(locale, 'nav.lang_switch_label')}
          >
            <Globe size={13} aria-hidden="true" class="block" />
            <span>{locale.toUpperCase()}</span>
          </button>
          <div
            id="lang-dropdown"
            hidden
            role="listbox"
            class="absolute right-0 top-full mt-2 min-w-[5rem] border border-brand-gold/20 py-1"
            style="background: rgba(20,10,30,0.97); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
          >
            <a
              href={fiHref}
              role="option"
              aria-selected={locale === 'fi'}
              class:list={[
                'block px-4 py-2 text-xs tracking-[0.15em] uppercase transition-colors',
                locale === 'fi' ? 'text-brand-gold' : 'text-brand-cream/70 hover:text-brand-cream',
              ]}
            >FI</a>
            <a
              href={enHref}
              role="option"
              aria-selected={locale === 'en'}
              class:list={[
                'block px-4 py-2 text-xs tracking-[0.15em] uppercase transition-colors',
                locale === 'en' ? 'text-brand-gold' : 'text-brand-cream/70 hover:text-brand-cream',
              ]}
            >EN</a>
          </div>
        </li>
      </ul>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t(locale, 'nav.open_menu')}
        class="md:hidden text-brand-cream/80 hover:text-brand-cream transition-colors p-1"
      >
        <Menu size={22} aria-hidden="true" />
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      hidden
      class="md:hidden border-t border-brand-gold/10"
      style="background: rgba(20,10,30,0.97); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
    >
      <ul class="px-6 py-4 flex flex-col gap-4" role="list">
        {navLinks.map(({ key, path }) => (
          <li>
            <a
              href={localePath(locale, path)}
              aria-current={isActive(path) ? 'page' : undefined}
              class:list={[
                'block text-sm tracking-[0.12em] uppercase transition-colors py-1',
                isActive(path)
                  ? 'text-brand-gold'
                  : 'text-brand-cream/80 hover:text-brand-cream',
              ]}
            >
              {t(locale, key)}
            </a>
          </li>
        ))}
        <li class="pt-2 border-t border-brand-gold/10 flex items-center gap-4">
          <a
            href={fiHref}
            class:list={[
              'text-xs tracking-[0.15em] uppercase transition-colors',
              locale === 'fi' ? 'text-brand-gold' : 'text-brand-cream/70 hover:text-brand-cream',
            ]}
          >FI</a>
          <span class="text-brand-gold/30" aria-hidden="true">|</span>
          <a
            href={enHref}
            class:list={[
              'text-xs tracking-[0.15em] uppercase transition-colors',
              locale === 'en' ? 'text-brand-gold' : 'text-brand-cream/70 hover:text-brand-cream',
            ]}
          >EN</a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style is:global>
  #site-nav {
    background-color: rgba(26, 12, 51, 0.60);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px); 
    border-bottom: 1px solid transparent;
  }
  #site-nav.nav-scrolled {
    background-color: rgba(26, 12, 51, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201, 169, 106, 0.1);
    transition: all 0.3s ease-in-out;
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => nav?.classList.toggle('nav-scrolled', window.scrollY > 30);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.hidden = expanded;
    });
  }

  const langToggle = document.getElementById('lang-toggle');
  const langDropdown = document.getElementById('lang-dropdown');
  if (langToggle && langDropdown) {
    langToggle.addEventListener('click', () => {
      const expanded = langToggle.getAttribute('aria-expanded') === 'true';
      langToggle.setAttribute('aria-expanded', String(!expanded));
      langDropdown.hidden = expanded;
    });
    document.addEventListener('click', (e) => {
      if (!langToggle.contains(e.target as Node) && !langDropdown.contains(e.target as Node)) {
        langToggle.setAttribute('aria-expanded', 'false');
        langDropdown.hidden = true;
      }
    });
  }
</script>
