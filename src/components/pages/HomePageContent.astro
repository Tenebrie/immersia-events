---
import { getImage, Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Sparkle from "../Sparkle.astro";
import GalleryGrid from "../GalleryGrid.astro";
import type { Locale } from "../../utils/i18n";
import { t, tArray, localePath } from "../../utils/i18n";
import venueImg3 from "../../assets/venue/IMG_7131-768x1024.jpeg";
import venueImg1 from "../../assets/venue/IMG_7141-768x1024.jpeg";
import venueImg2 from "../../assets/venue/IMG_7143-scaled.jpeg";

const EVENT_PATH = "/events/river-court-autumn-ball";
const TICKET_URL =
  "https://www.eventim-light.com/fi/a/696f92258d6c8567308d2023/e/697689789778dd35db2384fc";
const DISCORD_URL = "https://discord.gg/D65m6sgSqk";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const heroImageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/hero.{jpg,jpeg,webp,png}",
  { eager: true },
);
const heroImageRaw = Object.values(heroImageModules)[0]?.default;
const heroImage = heroImageRaw
  ? await getImage({ src: heroImageRaw, width: 1600, format: "webp" })
  : null;

const eventHref = localePath(locale, EVENT_PATH);

const galleryImageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/gallery/*.{jpg,jpeg,webp,png}",
  { eager: true },
);
const hasGalleryImages = Object.keys(galleryImageModules).length > 0;
---

<!-- Hero -->
<section
  class="relative min-h-screen flex items-end"
  style={heroImage
    ? `background-image: url('${heroImage.src}'); background-attachment: fixed; background-size: cover; background-position: center;`
    : "background: linear-gradient(135deg, #1a0c33 0%, #2a1248 50%, #3d1f63 100%);"}
  aria-labelledby="hero-heading"
>
  <!-- Bottom gradient: dark floor for the type -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to top, rgba(10,5,20,0.92), rgba(15,8,28,0.6) 40%, transparent 65%);"
    aria-hidden="true"
  >
  </div>
  <!-- Top gradient: nav legibility without a hard bar -->

  <!-- Content — left-aligned in content gutter -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 sm:px-8 pb-20 pt-8">
    <div>
      <p
        class="text-xs tracking-[0.25em] uppercase mb-5"
        style="color: var(--color-brand-gold); font-variant-caps: small-caps;"
        aria-hidden="true"
      >
        {t(locale, "home.hero.eyebrow")}
      </p>

      <h1
        id="hero-heading"
        class="font-display text-4xl md:text-6xl lg:text-7xl text-brand-cream tracking-wider leading-tight mb-8"
        style="text-shadow: 0 2px 24px rgba(15,5,25,0.6);"
      >
        {t(locale, "home.hero.title")}
      </h1>

      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a
          href={TICKET_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-tickets"
        >
          {t(locale, "home.hero.tickets_cta")}
        </a>
        <a
          href={eventHref}
          class="text-sm tracking-[0.12em] uppercase text-brand-cream/60 hover:text-brand-cream transition-colors sm:self-center"
        >
          {t(locale, "home.hero.cta")}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- What is a fantasy ball? -->
<section class="py-24 px-6" aria-labelledby="what-is-heading">
  <div class="max-w-2xl mx-auto text-center">
    <div class="section-rule" aria-hidden="true">
      <Sparkle size={12} class="text-brand-gold" />
    </div>
    <h2
      id="what-is-heading"
      class="font-display text-3xl md:text-4xl text-brand-cream tracking-wide mb-6"
    >
      {t(locale, "event_detail.what_is_heading")}
    </h2>
    <p class="text-brand-cream/70 leading-loose mb-5">
      {t(locale, "event_detail.what_is_body_1")}
    </p>
    <p class="text-brand-cream/70 leading-loose">
      {t(locale, "event_detail.what_is_body_3")}
    </p>
  </div>
</section>

<!-- Venue photos -->
<section class="py-12 px-6 bg-brand-purple/30" aria-labelledby="venue-heading">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <div class="section-rule" aria-hidden="true">
        <Sparkle size={12} class="text-brand-gold" />
      </div>
      <h2
        id="venue-heading"
        class="font-display text-3xl md:text-4xl text-brand-cream tracking-wide mb-4"
      >
        {t(locale, "home.venue.heading")}
      </h2>
      <p class="text-brand-cream/70 leading-loose max-w-2xl mx-auto">
        {t(locale, "event_detail.description_2")}
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4">
      <Image
        src={venueImg1}
        alt={t(locale, "home.venue.img_alt")}
        class="w-full aspect-[3/4] object-cover"
        width={768}
        height={1024}
      />
      <Image
        src={venueImg2}
        alt={t(locale, "home.venue.img_alt")}
        class="w-full aspect-[3/4] object-cover"
        width={768}
        height={1024}
      />
      <Image
        src={venueImg3}
        alt={t(locale, "home.venue.img_alt")}
        class="w-full aspect-[3/4] object-cover"
        width={768}
        height={1024}
      />
    </div>
  </div>
</section>

<!-- Gallery teaser -->
{
  hasGalleryImages && (
    <section class="py-24 px-6" aria-labelledby="gallery-teaser-heading">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-10">
          <div class="section-rule" aria-hidden="true">
            <Sparkle size={12} class="text-brand-gold" />
          </div>
          <h2
            id="gallery-teaser-heading"
            class="font-display text-3xl md:text-4xl text-brand-cream tracking-wide"
          >
            {t(locale, "home.gallery_teaser.heading")}
          </h2>
        </div>
        <GalleryGrid locale={locale} previewCount={3} />
        <div class="text-center mt-8">
          <a
            href={localePath(locale, "/gallery")}
            class="text-sm tracking-[0.15em] uppercase text-brand-gold hover:text-brand-gold-light transition-colors inline-flex items-center gap-2"
          >
            {t(locale, "home.gallery_teaser.link")}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  )
}

<!-- Dress code teaser -->
<section
  class="py-24 px-6 bg-brand-purple/30"
  aria-labelledby="dress-code-heading"
>
  <div class="max-w-2xl mx-auto text-center">
    <div class="section-rule" aria-hidden="true">
      <Sparkle size={12} class="text-brand-gold" />
    </div>
    <h2
      id="dress-code-heading"
      class="font-display text-3xl md:text-4xl text-brand-cream tracking-wide mb-6"
    >
      {t(locale, "event_detail.dress_code_heading")}
    </h2>
    <p class="text-brand-cream/70 leading-loose mb-4">
      {t(locale, "event_detail.dress_code_1")}
    </p>
    <p class="text-brand-cream/70 leading-loose mb-8">
      {t(locale, "event_detail.dress_code_2")}
    </p>
    <a
      href={eventHref}
      class="text-sm tracking-[0.15em] uppercase text-brand-gold hover:text-brand-gold-light transition-colors"
    >
      {t(locale, "home.dress_code_section.more")}
    </a>
  </div>
</section>

<!-- Programme: what's included -->
<section class="py-24 px-6" aria-labelledby="programme-heading">
  <div class="max-w-3xl mx-auto">
    <div class="section-rule" aria-hidden="true">
      <Sparkle size={12} class="text-brand-gold" />
    </div>
    <h2
      id="programme-heading"
      class="font-display text-3xl md:text-4xl text-brand-cream tracking-wide mb-10 text-center"
    >
      {t(locale, "event_detail.ticket_includes_heading")}
    </h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-4" role="list">
      {
        tArray(locale, "event_detail.ticket_includes").map((item) => (
          <li class="flex items-start gap-3">
            <Sparkle size={10} class="text-brand-gold shrink-0 mt-1.5" />
            <span class="text-sm text-brand-cream/70 leading-relaxed">
              {item}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- Ticket CTA -->
<section
  class="py-24 px-6 bg-brand-purple/30"
  aria-labelledby="tickets-cta-heading"
>
  <div class="max-w-xl mx-auto text-center">
    <div class="section-rule" aria-hidden="true">
      <Sparkle size={12} class="text-brand-gold" />
    </div>
    <h2
      id="tickets-cta-heading"
      class="font-display text-3xl md:text-4xl text-brand-cream tracking-wide mb-8"
    >
      {t(locale, "home.tickets_section.heading")}
    </h2>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={TICKET_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-tickets"
      >
        {t(locale, "home.hero.tickets_cta")}
      </a>
      <a
        href={eventHref}
        class="text-sm tracking-[0.12em] uppercase text-brand-cream/60 hover:text-brand-cream transition-colors"
      >
        {t(locale, "home.hero.cta")}
      </a>
    </div>
    <p class="text-xs text-brand-cream/40 mt-6 tracking-wide">
      {t(locale, "event_detail.ticket_vat_note")}
    </p>
  </div>
</section>
