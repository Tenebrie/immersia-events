---
import Sparkle from '../Sparkle.astro';
import type { Locale } from '../../utils/i18n';
import { t, localePath } from '../../utils/i18n';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  event: CollectionEntry<'events'>;
  locale: Locale;
}
const { event, locale } = Astro.props;

const { Content } = await render(event);

const title = locale === 'fi' ? event.data.titleFi : event.data.titleEn;
const dressCode = locale === 'fi' ? event.data.dressCodeFi : event.data.dressCodeEn;
---

<div class="pt-24 pb-32 px-6">
  <div class="max-w-2xl mx-auto">

    <!-- Back link -->
    <a
      href={localePath(locale, '/events')}
      class="text-xs tracking-[0.12em] uppercase text-brand-cream-muted hover:text-brand-cream transition-colors inline-flex items-center gap-2 mb-12"
    >
      {t(locale, 'events.details.back')}
    </a>

    <!-- Event header -->
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <Sparkle size={10} class="text-brand-gold/60" />
        <span class="text-xs tracking-[0.15em] uppercase text-brand-cream-muted">
          {t(locale, 'events.title')}
        </span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl text-brand-cream leading-tight tracking-wide mb-4">
        {title}
      </h1>

      <div class="flex flex-col gap-3 mt-8 border-t border-brand-gold/15 pt-8">
        <div class="grid grid-cols-[7rem_1fr] gap-2 text-sm">
          <span class="text-xs tracking-[0.12em] uppercase text-brand-gold/70 pt-0.5">
            {t(locale, 'events.details.when')}
          </span>
          <span class="text-brand-cream/80">{event.data.date}</span>
        </div>
        <div class="grid grid-cols-[7rem_1fr] gap-2 text-sm">
          <span class="text-xs tracking-[0.12em] uppercase text-brand-gold/70 pt-0.5">
            {t(locale, 'events.details.where')}
          </span>
          <span class="text-brand-cream/80">{event.data.venue}</span>
        </div>
      </div>
    </header>

    <div class="section-rule" aria-hidden="true">
      <Sparkle size={10} class="text-brand-gold" />
    </div>

    <!-- Body -->
    <section aria-labelledby="event-body-heading">
      <h2 id="event-body-heading" class="font-display text-2xl text-brand-cream tracking-wide mb-6">
        {t(locale, 'events.details.what_to_expect')}
      </h2>
      <div class="prose text-brand-cream/75 leading-loose space-y-4 [&_p]:mb-4">
        <Content />
      </div>
    </section>

    {dressCode && (
      <>
        <div class="section-rule" aria-hidden="true">
          <Sparkle size={10} class="text-brand-gold" />
        </div>
        <section aria-labelledby="dresscode-heading">
          <h2 id="dresscode-heading" class="font-display text-2xl text-brand-cream tracking-wide mb-4">
            {t(locale, 'events.details.dress_code')}
          </h2>
          <p class="text-brand-cream/70 leading-loose">{dressCode}</p>
        </section>
      </>
    )}

    <div class="section-rule" aria-hidden="true">
      <Sparkle size={10} class="text-brand-gold" />
    </div>

    <!-- FAQ -->
    <section aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="font-display text-2xl text-brand-cream tracking-wide mb-8">
        {t(locale, 'events.details.faq_heading')}
      </h2>
      <dl class="space-y-6">
        {(['1', '2'] as const).map((n) => (
          <div class="border-b border-brand-gold/10 pb-6">
            <dt class="font-display text-lg text-brand-cream mb-2">
              {t(locale, `events.details.faq_q${n}`)}
            </dt>
            <dd class="text-sm text-brand-cream/65 leading-relaxed">
              {t(locale, `events.details.faq_a${n}`)}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <div class="section-rule" aria-hidden="true">
      <Sparkle size={10} class="text-brand-gold" />
    </div>

    <!-- Tickets -->
    <section aria-labelledby="tickets-heading" class="text-center py-6">
      <h2 id="tickets-heading" class="font-display text-2xl text-brand-cream tracking-wide mb-6">
        {t(locale, 'events.details.tickets_heading')}
      </h2>
      <p class="text-brand-cream/60 text-sm leading-relaxed italic">
        {t(locale, 'events.details.tickets_cta')}
      </p>
    </section>

  </div>
</div>
