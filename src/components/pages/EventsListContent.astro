---
import { getCollection } from 'astro:content';
import Sparkle from '../Sparkle.astro';
import EventCard from '../EventCard.astro';
import type { Locale } from '../../utils/i18n';
import { t } from '../../utils/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const events = await getCollection('events');
events.sort((a, b) => a.data.order - b.data.order);
---

<div class="pt-24 pb-32 px-6">
  <div class="max-w-3xl mx-auto">

    <header class="text-center mb-16">
      <div class="section-rule" aria-hidden="true">
        <Sparkle size={12} class="text-brand-gold" />
      </div>
      <h1 class="font-display text-4xl md:text-5xl text-brand-cream tracking-wide mb-4">
        {t(locale, 'events.title')}
      </h1>
      <p class="text-brand-cream/60 leading-relaxed">
        {t(locale, 'events.subtitle')}
      </p>
    </header>

    {events.length === 0 ? (
      <p class="text-center text-brand-cream-muted py-12">
        {t(locale, 'events.no_events')}
      </p>
    ) : (
      <ul class="flex flex-col gap-6" role="list">
        {events.map((event) => (
          <li>
            <EventCard event={event} locale={locale} />
          </li>
        ))}
      </ul>
    )}
  </div>
</div>
