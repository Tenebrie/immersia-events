---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EventDetailContent from '../../../components/pages/EventDetailContent.astro';

const events = await getCollection('events');
const event = events.find((e) => e.id === 'first-evening')!;
const title = event.data.titleEn;
---
<BaseLayout locale="en" title={title}>
  <EventDetailContent event={event} locale="en" />
</BaseLayout>
